---
import { existsSync } from 'fs';
import { join } from 'path';

async function fetchOgImage(url: string): Promise<string | null> {
  try {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), 5000);
    const res = await fetch(url, { signal: controller.signal });
    clearTimeout(id);
    const html = await res.text();
    const match =
      html.match(/<meta[^>]+property="og:image"[^>]+content="([^"]+)"/i) ||
      html.match(/<meta[^>]+content="([^"]+)"[^>]+property="og:image"/i);
    return match ? match[1] : null;
  } catch {
    return null;
  }
}

function localImage(filename: string): string | null {
  const abs = join(process.cwd(), 'public', 'images', 'works', filename);
  return existsSync(abs) ? `/images/works/${filename}` : null;
}

const [ogFoodExam, ogFaceScore, ogBlog, ogZenn] = await Promise.all([
  fetchOgImage('https://www.food-exam.com/'),
  fetchOgImage('https://line.me/R/ti/p/@207hhrmi'),
  fetchOgImage('https://freeheroblog.com/'),
  fetchOgImage('https://zenn.dev/kunihero'),
]);

const thumbFoodExam = ogFoodExam || localImage('foodexam.png');
const thumbFaceScore = ogFaceScore || localImage('face-score.png');
const thumbBlog = localImage('blog.png'); // OGPは外れているためスキップ
const thumbZenn = ogZenn || localImage('zenn.png');

function profileImagePath(): string | null {
  for (const ext of ['jpg', 'jpeg', 'png', 'webp']) {
    const abs = join(process.cwd(), 'public', 'images', `profile.${ext}`);
    if (existsSync(abs)) return `/images/profile.${ext}`;
  }
  return null;
}
const profileImage = profileImagePath();
---
<!DOCTYPE html>
<html lang="ja" data-lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>kuni — Full-Stack Engineer & PM</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --color-bg: #FAFAF8;
  --color-bg-alt: #F0EFEB;
  --color-bg-card: #FFFFFF;
  --color-text: #1A1A1A;
  --color-text-muted: #6B6B6B;
  --color-text-light: #9A9A9A;
  --color-accent: #2D5A3D;
  --color-accent-light: #3D7A52;
  --color-accent-bg: #E8F0EB;
  --color-border: #E0DDD8;
  --color-border-light: #ECEAE5;
  --color-hero-bg: #1A1F1C;
  --color-hero-text: #F5F5F0;
  --color-hero-muted: #A0A89A;
  --color-tag-bg: #F0EFEB;
  --color-tag-text: #4A4A4A;
  --font-sans: 'DM Sans', 'Noto Sans JP', sans-serif;
  --font-jp: 'Noto Sans JP', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --space-xs: 0.5rem; --space-sm: 1rem; --space-md: 1.5rem;
  --space-lg: 3rem; --space-xl: 5rem; --space-2xl: 8rem;
  --radius-sm: 6px; --radius-md: 12px; --radius-lg: 20px;
  --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; -webkit-font-smoothing: antialiased; }
body { font-family: var(--font-sans); background: var(--color-bg); color: var(--color-text); line-height: 1.7; overflow-x: hidden; }
img { max-width: 100%; display: block; } a { color: inherit; text-decoration: none; } button { cursor: pointer; border: none; background: none; font: inherit; }
::selection { background: var(--color-accent); color: white; }

/* NAV */
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; transition: var(--transition); background: transparent; }
.nav.scrolled { background: rgba(250,250,248,0.92); backdrop-filter: blur(20px); border-bottom: 1px solid var(--color-border-light); }
.nav-logo { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.05em; color: var(--color-hero-text); transition: var(--transition); }
.nav.scrolled .nav-logo { color: var(--color-text); }
.nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
.nav-links a { font-size: 0.82rem; font-weight: 500; letter-spacing: 0.03em; color: var(--color-hero-muted); transition: var(--transition); position: relative; }
.nav.scrolled .nav-links a { color: var(--color-text-muted); }
.nav-links a:hover { color: var(--color-accent-light); }
.nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1.5px; background: var(--color-accent); transition: var(--transition); }
.nav-links a:hover::after { width: 100%; }
.lang-toggle { font-family: var(--font-mono); font-size: 0.75rem; padding: 0.35rem 0.75rem; border: 1px solid rgba(255,255,255,0.25); border-radius: 100px; color: var(--color-hero-muted); transition: var(--transition); letter-spacing: 0.05em; }
.nav.scrolled .lang-toggle { border-color: var(--color-border); color: var(--color-text-muted); }
.lang-toggle:hover { background: var(--color-accent); color: white; border-color: var(--color-accent); }
.nav-hamburger { display: none; flex-direction: column; gap: 5px; padding: 4px; }
.nav-hamburger span { width: 22px; height: 1.5px; background: var(--color-hero-text); transition: var(--transition); }
.nav.scrolled .nav-hamburger span { background: var(--color-text); }
@media (max-width: 768px) {
  .nav-hamburger { display: flex; }
  .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--color-bg); flex-direction: column; padding: 2rem; gap: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .nav-links.open { display: flex; }
  .nav-links a, .nav.scrolled .nav-links a { color: var(--color-text); }
  .lang-toggle { border-color: var(--color-border); color: var(--color-text-muted); }
}

/* HERO */
.hero { min-height: 100vh; background: var(--color-hero-bg); display: flex; align-items: center; position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; top: -30%; right: -10%; width: 60%; height: 80%; background: radial-gradient(ellipse, rgba(45,90,61,0.15) 0%, transparent 70%); pointer-events: none; }
.hero-inner { max-width: 1100px; margin: 0 auto; padding: 8rem 2rem 4rem; width: 100%; }
.hero-label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-accent-light); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
.hero-name { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; color: var(--color-hero-text); line-height: 1.15; margin-bottom: 1.5rem; opacity: 0; animation: fadeUp 0.8s 0.4s forwards; }
.hero-title { font-size: clamp(1rem, 2.5vw, 1.2rem); font-weight: 400; color: var(--color-hero-muted); margin-bottom: 1.5rem; opacity: 0; animation: fadeUp 0.8s 0.5s forwards; }
.hero-description { max-width: 540px; font-size: 0.95rem; color: rgba(245,245,240,0.55); line-height: 1.85; margin-bottom: 3rem; opacity: 0; animation: fadeUp 0.8s 0.6s forwards; }
.hero-links { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.8s 0.7s forwards; }
.hero-link { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; font-weight: 500; color: var(--color-hero-muted); padding: 0.6rem 1.2rem; border: 1px solid rgba(255,255,255,0.12); border-radius: 100px; transition: var(--transition); }
.hero-link:hover { border-color: var(--color-accent-light); color: var(--color-accent-light); background: rgba(45,90,61,0.1); }
.hero-link svg { width: 16px; height: 16px; }
.hero-scroll { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; opacity: 0; animation: fadeUp 0.8s 1s forwards; }
.hero-scroll span { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--color-hero-muted); writing-mode: vertical-lr; }
.hero-scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--color-hero-muted), transparent); animation: scrollPulse 2s ease-in-out infinite; }
@keyframes scrollPulse { 0%,100% { opacity: 1; transform: scaleY(1); } 50% { opacity: 0.3; transform: scaleY(0.6); } }

/* SECTIONS */
.section { padding: var(--space-2xl) 2rem; max-width: 1100px; margin: 0 auto; }
.section-header { margin-bottom: var(--space-xl); }
.section-label { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.75rem; }
.section-title { font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 700; line-height: 1.2; }
.section-divider { width: 40px; height: 2px; background: var(--color-accent); margin-top: 1.25rem; }

/* ABOUT */
.about-grid { display: grid; grid-template-columns: 280px 1fr; gap: var(--space-xl); align-items: start; }
.about-photo { aspect-ratio: 3/4; border-radius: var(--radius-md); background: var(--color-bg-alt); display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid var(--color-border-light); }
.about-photo-placeholder { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-light); }
.about-content p { font-size: 0.95rem; color: var(--color-text-muted); margin-bottom: 1.25rem; line-height: 1.9; }
.about-meta { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; padding-top: 2rem; border-top: 1px solid var(--color-border-light); }
.about-meta-item label { display: block; font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-light); margin-bottom: 0.3rem; }
.about-meta-item span { font-size: 0.9rem; font-weight: 500; }
@media (max-width: 768px) { .about-grid { grid-template-columns: 1fr; gap: 2rem; } .about-photo { max-width: 220px; } }

/* TIMELINE */
.timeline { position: relative; padding-left: 2rem; }
.timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 1px; background: var(--color-border); }
.timeline-item { position: relative; padding-bottom: 3rem; padding-left: 2rem; }
.timeline-item:last-child { padding-bottom: 0; }
.timeline-dot { position: absolute; left: -2.45rem; top: 0.4rem; width: 10px; height: 10px; border-radius: 50%; background: var(--color-bg); border: 2px solid var(--color-accent); }
.timeline-item.highlight .timeline-dot { background: var(--color-accent); box-shadow: 0 0 0 4px var(--color-accent-bg); }
.timeline-year { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-accent); letter-spacing: 0.05em; margin-bottom: 0.3rem; }
.timeline-role { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.25rem; }
.timeline-company { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.5rem; }
.timeline-desc { font-size: 0.88rem; color: var(--color-text-muted); line-height: 1.75; }
.timeline-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.75rem; }
.timeline-tag { font-family: var(--font-mono); font-size: 0.68rem; padding: 0.2rem 0.6rem; background: var(--color-tag-bg); color: var(--color-tag-text); border-radius: 100px; }

/* SKILLS */
.skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
.skill-card { background: var(--color-bg-card); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 2rem; transition: var(--transition); }
.skill-card:hover { border-color: var(--color-accent); box-shadow: 0 4px 24px rgba(45,90,61,0.06); transform: translateY(-2px); }
.skill-card-icon { width: 40px; height: 40px; border-radius: var(--radius-sm); background: var(--color-accent-bg); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; font-size: 1.1rem; }
.skill-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; }
.skill-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.skill-item { font-family: var(--font-mono); font-size: 0.72rem; padding: 0.3rem 0.7rem; background: var(--color-tag-bg); color: var(--color-tag-text); border-radius: 100px; transition: var(--transition); }
.skill-item:hover { background: var(--color-accent); color: white; }

/* WORKS */
.works-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
.work-card { background: var(--color-bg-card); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); overflow: hidden; transition: var(--transition); }
.work-card:hover { border-color: var(--color-border); box-shadow: 0 8px 32px rgba(0,0,0,0.06); transform: translateY(-3px); }
.work-card-thumb { aspect-ratio: 16/9; background: var(--color-bg-alt); display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--color-border-light); overflow: hidden; }
.work-card-thumb img { width: 100%; height: 100%; object-fit: cover; }
.work-card-thumb-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; background: linear-gradient(135deg, var(--color-bg-alt) 0%, var(--color-accent-bg) 100%); }
.work-card-thumb-placeholder .thumb-initial { font-family: var(--font-mono); font-size: 2.5rem; font-weight: 700; color: var(--color-accent); line-height: 1; }
.work-card-thumb-placeholder .thumb-name { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-light); }
.work-card-thumb-label { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-light); }
.work-card-body { padding: 1.5rem; }
.work-card-type { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.5rem; }
.work-card h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; }
.work-card p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 1rem; }
.work-card-links { display: flex; gap: 0.75rem; }
.work-card-link { font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-accent); display: inline-flex; align-items: center; gap: 0.3rem; transition: var(--transition); }
.work-card-link:hover { color: var(--color-accent-light); }
.work-card-link svg { width: 14px; height: 14px; }

/* CERTS */
.certs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }
.cert-group h3 { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
.cert-list { list-style: none; }
.cert-list li { font-size: 0.82rem; color: var(--color-text-muted); padding: 0.4rem 0; border-bottom: 1px solid var(--color-border-light); display: flex; justify-content: space-between; align-items: center; }
.cert-list li:last-child { border-bottom: none; }
.cert-year { font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-text-light); flex-shrink: 0; margin-left: 0.5rem; }

/* HOBBIES */
.hobbies-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
.hobby-card { padding: 2rem; background: var(--color-bg-card); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); }
.hobby-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
.hobby-card p { font-size: 0.88rem; color: var(--color-text-muted); line-height: 1.8; }
.country-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.75rem; }
.country-tag { font-size: 0.72rem; padding: 0.2rem 0.55rem; background: var(--color-tag-bg); color: var(--color-tag-text); border-radius: 100px; }
.race-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.75rem; }
.race-tag { font-size: 0.72rem; padding: 0.2rem 0.55rem; background: var(--color-accent-bg); color: var(--color-accent); border-radius: 100px; }

/* VALUES & QUOTES */
.values-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
.value-card { padding: 2rem; background: var(--color-bg-card); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); }
.value-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--color-accent); }
.value-card p { font-size: 0.88rem; color: var(--color-text-muted); line-height: 1.8; }
.quote-item { padding: 2rem; border-left: 3px solid var(--color-accent); margin-bottom: 1.5rem; background: var(--color-bg-card); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
.quote-text { font-size: 0.95rem; font-style: italic; line-height: 1.85; margin-bottom: 0.75rem; color: var(--color-text); }
.quote-source { font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-text-light); }
.quote-comment { font-size: 0.85rem; color: var(--color-text-muted); margin-top: 0.5rem; line-height: 1.7; }

/* CONTACT */
.contact-section { background: var(--color-hero-bg); color: var(--color-hero-text); padding: var(--space-2xl) 2rem; }
.contact-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: start; }
.contact-info .section-label { color: var(--color-accent-light); }
.contact-info .section-title { color: var(--color-hero-text); }
.contact-info .section-divider { background: var(--color-accent-light); }
.contact-text { font-size: 0.95rem; color: var(--color-hero-muted); line-height: 1.8; margin-top: 1.5rem; }
.contact-links-list { list-style: none; margin-top: 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
.contact-links-list a { font-size: 0.88rem; color: var(--color-hero-muted); display: inline-flex; align-items: center; gap: 0.6rem; transition: var(--transition); }
.contact-links-list a:hover { color: var(--color-accent-light); }
.contact-links-list svg { width: 18px; height: 18px; opacity: 0.6; }
.contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
.form-group label { display: block; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-hero-muted); margin-bottom: 0.5rem; }
.form-group input, .form-group textarea { width: 100%; padding: 0.85rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-sm); color: var(--color-hero-text); font-family: var(--font-sans); font-size: 0.9rem; transition: var(--transition); outline: none; }
.form-group input:focus, .form-group textarea:focus { border-color: var(--color-accent-light); background: rgba(255,255,255,0.08); }
.form-group textarea { min-height: 140px; resize: vertical; }
.form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,0.2); }
.form-submit { align-self: flex-start; padding: 0.85rem 2.5rem; background: var(--color-accent); color: white; border-radius: 100px; font-size: 0.85rem; font-weight: 500; transition: var(--transition); }
.form-submit:hover { background: var(--color-accent-light); transform: translateY(-1px); }
@media (max-width: 768px) { .contact-inner { grid-template-columns: 1fr; } }

.footer { background: var(--color-hero-bg); border-top: 1px solid rgba(255,255,255,0.05); padding: 2rem; text-align: center; }
.footer p { font-family: var(--font-mono); font-size: 0.7rem; color: rgba(255,255,255,0.25); }

@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
.fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
.fade-in.visible { opacity: 1; transform: translateY(0); }
.section-full { background: var(--color-bg-alt); padding: var(--space-2xl) 2rem; }
.section-full-inner { max-width: 1100px; margin: 0 auto; }
[data-lang="ja"] .en-only { display: none; }
[data-lang="en"] .ja-only { display: none; }
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav" id="nav">
  <div class="nav-logo">kuni</div>
  <ul class="nav-links" id="navLinks">
    <li><a href="#about"><span class="ja-only">自己紹介</span><span class="en-only">About</span></a></li>
    <li><a href="#life"><span class="ja-only">人生</span><span class="en-only">Life</span></a></li>
    <li><a href="#skills"><span class="ja-only">スキル</span><span class="en-only">Skills</span></a></li>
    <li><a href="#works"><span class="ja-only">制作物</span><span class="en-only">Works</span></a></li>
    <li><a href="#hobbies"><span class="ja-only">趣味</span><span class="en-only">Hobbies</span></a></li>
    <li><a href="#values"><span class="ja-only">大事にしていること</span><span class="en-only">Values</span></a></li>
    <li><a href="#contact"><span class="ja-only">お問い合わせ</span><span class="en-only">Contact</span></a></li>
    <li><button class="lang-toggle" onclick="toggleLang()">EN / JA</button></li>
  </ul>
  <button class="nav-hamburger" onclick="toggleMenu()" aria-label="Menu"><span></span><span></span><span></span></button>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-label">Portfolio</div>
    <h1 class="hero-name">kuni</h1>
    <p class="hero-title">Full-Stack Engineer & Product Manager</p>
